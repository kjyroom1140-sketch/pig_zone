# EditorConfig - 팀/프로젝트 공통 포맷
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{js,ts,tsx,json,css}]
indent_style = space
indent_size = 2

[*.go]
indent_style = tab
indent_size = 4

[*.{bat,cmd}]
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false
